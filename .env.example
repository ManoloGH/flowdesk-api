# Base de datos
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/flowdesk"

# JWT
JWT_SECRET="tu-clave-secreta-muy-larga"
JWT_EXPIRES_IN="7d"

# App
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_SERVICE_KEY="tu-service-key"

# Encriptación
ENCRYPTION_KEY="clave-de-32-caracteres-minimo"

# AI
ANTHROPIC_API_KEY="sk-ant-..."
DEEPGRAM_API_KEY="..."

# Google OAuth (Gmail + Calendar)
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-..."
GOOGLE_REDIRECT_URI="http://localhost:3001/integrations/google/callback"

# Microsoft 365 OAuth (Outlook + Teams)
MS_CLIENT_ID="..."
MS_CLIENT_SECRET="..."
MS_TENANT_ID="common"
MS_REDIRECT_URI="http://localhost:3001/integrations/microsoft/callback"

# Webhooks
FLOWDESK_WEBHOOK_SECRET="secreto-aleatorio-seguro"

# Frontend (para redirects OAuth)
FRONTEND_URL="http://localhost:3000"
